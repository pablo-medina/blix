{
  "name": "blix-game",
  "version": "1.0.0",
  "description": "A breakout-style game built with Electron",
  "main": "index.html",
  "scripts": {
    "start": "npm run dev",
    "dev": "npm run start:web",
    "tauri:dev": "npm run build:web && npx tauri dev",
    "tauri:build": "npm run build:web && npx tauri build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:web": "webpack --mode production",
    "start:web": "node scripts/start-web.js",
    "android:sync": "npx cap sync android",
    "android:add": "npx cap add android",
    "build:android": "npm run build:web && npx cap copy android && cd android && gradlew.bat assembleDebug"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@tauri-apps/api": "^1.5.3"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "open": "^10.1.2",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "@types/node": "^22.5.0",
    "@capacitor/cli": "^6.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "@tauri-apps/cli": "^1.5.11"
  }
}
